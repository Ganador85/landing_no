# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PAYLOAD_SECRET=dev-secret-change-me-in-production-32chars

# Local default: SQLite (no Docker needed).
# Production / Docker: postgres://payload:payload@db:5432/takfornying
DATABASE_URL=file:./takfornying.db

# Vercel Blob (Media uploads). Create in Vercel → Storage → Blob,
# then copy BLOB_READ_WRITE_TOKEN into Vercel env + local .env
BLOB_READ_WRITE_TOKEN=

# Lead notifications (optional – logs to console if unset)
RESEND_API_KEY=
LEAD_FROM_EMAIL=leads@takfornyelse.no
LEAD_TO_EMAIL=post@takfornyelse.no
